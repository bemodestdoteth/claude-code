# =============================================================================
# Claude Code CLI — Environment Variable Reference
# =============================================================================
# Copy this file to .env and fill in the values you need.
# Bun automatically loads .env from the project root before running any script.
# Only set the variables relevant to your chosen provider/configuration.
# =============================================================================


# -----------------------------------------------------------------------------
# PROVIDER SELECTION
# Set exactly one of these to 1 to switch providers.
# If none are set, the Anthropic direct API is used (default).
# -----------------------------------------------------------------------------

# CLAUDE_CODE_USE_BEDROCK=1
# CLAUDE_CODE_USE_VERTEX=1
# CLAUDE_CODE_USE_FOUNDRY=1


# -----------------------------------------------------------------------------
# ANTHROPIC DIRECT API (default provider)
# -----------------------------------------------------------------------------

# API key (sk-ant-…). Takes highest priority for auth; disables OAuth if set.
# ANTHROPIC_API_KEY=

# Bearer token placed in Authorization: Bearer header instead of x-api-key.
# ANTHROPIC_AUTH_TOKEN=

# Override the Anthropic API base URL.
# Use this to point at a LiteLLM proxy or any Anthropic-API-compatible gateway.
# When set to a non api.anthropic.com host, some first-party features are disabled.
# ANTHROPIC_BASE_URL=

# Newline-separated "Name: Value" header pairs injected on every API request.
# Useful for proxy auth headers, e.g.: Authorization: Bearer <gateway-key>
# ANTHROPIC_CUSTOM_HEADERS=


# -----------------------------------------------------------------------------
# MODEL SELECTION
# Priority: /model slash command > --model flag > env var > settings.json > default
# Accepts full model IDs (e.g. claude-sonnet-4-6) or aliases: opus, sonnet, haiku
# -----------------------------------------------------------------------------

# Main conversation model.
# ANTHROPIC_MODEL=

# Small/fast model used for background tool-calls (default: Haiku).
# ANTHROPIC_SMALL_FAST_MODEL=

# Force all AgentTool subagents to a specific model.
# CLAUDE_CODE_SUBAGENT_MODEL=

# Override what each alias resolves to.
# ANTHROPIC_DEFAULT_OPUS_MODEL=
# ANTHROPIC_DEFAULT_SONNET_MODEL=
# ANTHROPIC_DEFAULT_HAIKU_MODEL=

# Inject a custom model ID into the /model picker UI (bypasses API validation).
# ANTHROPIC_CUSTOM_MODEL_OPTION=
# ANTHROPIC_CUSTOM_MODEL_OPTION_NAME=
# ANTHROPIC_CUSTOM_MODEL_OPTION_DESCRIPTION=

# Set to 1 to disable automatic remapping of deprecated Opus 4.0/4.1 IDs.
# CLAUDE_CODE_DISABLE_LEGACY_MODEL_REMAP=


# -----------------------------------------------------------------------------
# AWS BEDROCK  (requires CLAUDE_CODE_USE_BEDROCK=1)
# -----------------------------------------------------------------------------

# AWS_REGION=us-east-1
# ANTHROPIC_SMALL_FAST_MODEL_AWS_REGION=us-east-1

# Override the Bedrock endpoint URL.
# ANTHROPIC_BEDROCK_BASE_URL=

# Bearer token for Bedrock API key authentication (sets Authorization: Bearer).
# AWS_BEARER_TOKEN_BEDROCK=

# Set to 1 to skip AWS credential resolution (for use with local auth-injecting proxies).
# CLAUDE_CODE_SKIP_BEDROCK_AUTH=


# -----------------------------------------------------------------------------
# GCP VERTEX AI  (requires CLAUDE_CODE_USE_VERTEX=1)
# -----------------------------------------------------------------------------

# GCP project ID. Avoids 12-second metadata server timeout when ADC is absent.
# ANTHROPIC_VERTEX_PROJECT_ID=

# Default GCP region for Vertex models (default: us-east5).
# CLOUD_ML_REGION=

# Path to a GCP service account JSON key file.
# GOOGLE_APPLICATION_CREDENTIALS=

# Standard GCP project env vars (used by google-auth-library).
# GCLOUD_PROJECT=
# GOOGLE_CLOUD_PROJECT=

# Override the Vertex AI endpoint URL.
# ANTHROPIC_VERTEX_BASE_URL=

# Per-model region overrides for Vertex AI.
# VERTEX_REGION_CLAUDE_HAIKU_4_5=
# VERTEX_REGION_CLAUDE_3_5_HAIKU=
# VERTEX_REGION_CLAUDE_3_5_SONNET=
# VERTEX_REGION_CLAUDE_3_7_SONNET=
# VERTEX_REGION_CLAUDE_4_0_SONNET=
# VERTEX_REGION_CLAUDE_4_5_SONNET=
# VERTEX_REGION_CLAUDE_4_6_SONNET=
# VERTEX_REGION_CLAUDE_4_0_OPUS=
# VERTEX_REGION_CLAUDE_4_1_OPUS=

# Set to 1 to skip GCP credential resolution (for use with local auth-injecting proxies).
# CLAUDE_CODE_SKIP_VERTEX_AUTH=


# -----------------------------------------------------------------------------
# AZURE FOUNDRY  (requires CLAUDE_CODE_USE_FOUNDRY=1)
# -----------------------------------------------------------------------------

# Azure resource name — constructs endpoint https://{resource}.services.ai.azure.com/anthropic/v1/messages
# ANTHROPIC_FOUNDRY_RESOURCE=

# Alternatively, provide the full Foundry base URL directly.
# ANTHROPIC_FOUNDRY_BASE_URL=

# Azure Foundry API key. Falls back to DefaultAzureCredential if unset.
# ANTHROPIC_FOUNDRY_API_KEY=

# Set to 1 to skip Azure AD credential resolution (for use with local auth-injecting proxies).
# CLAUDE_CODE_SKIP_FOUNDRY_AUTH=


# -----------------------------------------------------------------------------
# INFERENCE / REQUEST TUNING
# -----------------------------------------------------------------------------

# Request timeout in milliseconds (default: 600000 = 10 minutes).
# API_TIMEOUT_MS=

# Override max_tokens sent on every API request (bounded by model's native limit).
# CLAUDE_CODE_MAX_OUTPUT_TOKENS=

# Override extended-thinking token budget.
# MAX_THINKING_TOKENS=

# Set to 1 to disable fast mode (lower token limits for speedier replies).
# CLAUDE_CODE_DISABLE_FAST_MODE=


# -----------------------------------------------------------------------------
# NETWORK / TLS / PROXY
# -----------------------------------------------------------------------------

# Standard HTTP(S) proxy URL applied to all outbound requests.
# HTTPS_PROXY=
# HTTP_PROXY=

# Comma- or space-separated hostnames/patterns to bypass the proxy.
# NO_PROXY=

# Path to a PEM file with additional trusted CA certificates.
# NODE_EXTRA_CA_CERTS=

# mTLS client certificate and key (PEM paths).
# CLAUDE_CODE_CLIENT_CERT=
# CLAUDE_CODE_CLIENT_KEY=
# CLAUDE_CODE_CLIENT_KEY_PASSPHRASE=

# Unix socket path for claude ssh proxy mode (tunnels all API traffic through a local relay).
# ANTHROPIC_UNIX_SOCKET=

# Set to 1 to let the proxy resolve hostnames instead of the local DNS resolver.
# CLAUDE_CODE_PROXY_RESOLVES_HOSTS=


# -----------------------------------------------------------------------------
# OAUTH / SESSION (advanced / integration use)
# -----------------------------------------------------------------------------

# Pre-supplied Claude.ai OAuth access token (used by IDE/desktop integrations).
# CLAUDE_CODE_OAUTH_TOKEN=
