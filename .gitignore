# .gitignore - Files to exclude from version control
# ============================================================================

# ============================================================================
# SYSTEM FILES
# ============================================================================
.DS_Store

# ============================================================================
# ENVIRONMENTS
# ============================================================================
.env
*.env

# ============================================================================
# PACKAGE MANAGERS
# ============================================================================
node_modules/

# ============================================================================
# BUILD & DISTRIBUTION ARTIFACTS
# ============================================================================
dist/
build/

# ============================================================================
# UNIT TEST & COVERAGE REPORTS
# ============================================================================
coverage/
.cache/

# ============================================================================
# BUILD CACHES
# ============================================================================
.turbo/

# ============================================================================
# LOGS & TEMPORARY FILES
# ============================================================================
*.log
*.tmp
*.swp
*.swo

# ============================================================================
# IDE & EDITOR FILES
# ============================================================================
.idea/
.vscode/

# ============================================================================
# Claude
# ============================================================================
.claude/
.omc/

# ============================================================================
# nfs
# ============================================================================
.nfs*

# ============================================================================
# Codegraph
# ============================================================================
.codegraph/
